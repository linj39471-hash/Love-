vents-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="aa560260-6c08-4e8d-b66f-efb774ae393f" data-turn-id-container="aa560260-6c08-4e8d-b66f-efb774ae393f" data-testid="conversation-turn-29" data-turn="user"><h4 class="sr-only select-none">You said:</h4><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div data-conversation-screenshot-content="" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="user" data-message-id="aa560260-6c08-4e8d-b66f-efb774ae393f" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/0.98 relative min-w-0 overflow-hidden rounded-[22px] px-4 py-2.5 leading-6 max-w-(--user-chat-width,70%)"><div class="max-w-full min-w-0 [overflow-wrap:anywhere] whitespace-pre-wrap">问题是酒馆不能链接本地的东西，只能上传我要怎么上传这是github，还是脚本</div></div></div></div></div><div class="z-0 flex justify-end"><div aria-label="Your message actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Edit message" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></section></div><div class="" data-turn-id-container="00251052-e32f-4bc4-8ab2-2c61cb76f7c7" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="00251052-e32f-4bc4-8ab2-2c61cb76f7c7" data-turn-id-container="00251052-e32f-4bc4-8ab2-2c61cb76f7c7" data-testid="conversation-turn-30" data-turn="assistant"><h4 class="sr-only select-none">ChatGPT said:</h4><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div data-conversation-screenshot-content="" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="470d0bbb-ec1b-402f-aec3-b3cb79773d43" dir="auto" data-message-model-slug="gpt-5-5-thinking" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full light markdown-new-styling"><p data-start="0" data-end="71" data-is-last-node="" data-is-only-node="">你这种情况最适合走 <strong data-start="10" data-end="25">GitHub 扩展仓库</strong>，不是正则，也不是单独上传一个脚本文件。我先按酒馆当前的安装方式确认一下具体入口和仓库结构。</p></div></div></div><div class="flex items-center justify-between"><div class="flex min-w-0 items-center"><button type="button" class="text-token-text-tertiary hover:text-token-text-primary dark:hover:text-token-text-primary flex items-center gap-0.5 text-start dark:text-(--interactive-label-tertiary-default)">Thought for 9s<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="icon-xs"><use href="/cdn/assets/sprites-core-c74d0474.svg#b140e7" fill="currentColor"></use></svg></button></div></div><div data-message-author-role="assistant" data-message-id="46d0900b-64bc-4ad3-bed8-b35da3fdeec0" dir="auto" data-message-model-slug="gpt-5-5-thinking" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full light markdown-new-styling"><p data-start="0" data-end="12">你这个情况应该这样理解：</p>
<blockquote data-start="14" data-end="61">
<p data-start="16" data-end="61"><strong data-start="16" data-end="61">它本质上是“酒馆扩展”，放在 GitHub 上，酒馆通过 GitHub 地址安装。</strong></p>
</blockquote>
<p data-start="63" data-end="106">它<strong data-start="64" data-end="70">不是</strong>酒馆里的正则，也不是“脚本库”里导入的单个 JavaScript 脚本。</p>
<h2 data-section-id="c9uzwr" data-start="108" data-end="119">你实际要做的流程</h2>
<h3 data-section-id="yxbhiq" data-start="121" data-end="140">第一步：准备一个完整扩展文件夹</h3>
<p data-start="142" data-end="147">里面包含：</p>
<pre class="overflow-visible! px-0!" data-start="149" data-end="270"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>NGNL-Stockfish-Chess/</span><br><span>├─ manifest.json</span><br><span>├─ index.js</span><br><span>├─ style.css</span><br><span>├─ chess.js</span><br><span>├─ stockfish.js</span><br><span>└─ stockfish.wasm</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="272" data-end="275">其中：</p>
<ul data-start="277" data-end="411">
<li data-section-id="oexk7t" data-start="277" data-end="294">
<p data-start="279" data-end="294"><code data-start="279" data-end="289">index.js</code>：控制棋盘</p>
</li>
<li data-section-id="1i0c2a" data-start="295" data-end="313">
<p data-start="297" data-end="313"><code data-start="297" data-end="308">style.css</code>：界面外观</p>
</li>
<li data-section-id="n2e4b7" data-start="314" data-end="335">
<p data-start="316" data-end="335"><code data-start="316" data-end="326">chess.js</code>：判断走法是否合法</p>
</li>
<li data-section-id="14pp36a" data-start="336" data-end="382">
<p data-start="338" data-end="382"><code data-start="338" data-end="352">stockfish.js</code>和<code data-start="353" data-end="369">stockfish.wasm</code>：特图的高强度国际象棋AI</p>
</li>
<li data-section-id="17ueuik" data-start="383" data-end="411">
<p data-start="385" data-end="411"><code data-start="385" data-end="400">manifest.json</code>：告诉酒馆这是一个扩展</p>
</li>
</ul>
<h3 data-section-id="19uneze" data-start="413" data-end="437">第二步：把整个文件夹上传到 GitHub</h3>
<p data-start="439" data-end="464">不是只上传一个脚本，也不是只上传 <code data-start="456" data-end="463">.wasm</code>。</p>
<p data-start="466" data-end="488">GitHub仓库打开后，第一层就应该能看到：</p>
<pre class="overflow-visible! px-0!" data-start="490" data-end="562"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>manifest.json</span><br><span>index.js</span><br><span>style.css</span><br><span>stockfish.js</span><br><span>stockfish.wasm</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<h3 data-section-id="10s4hmd" data-start="564" data-end="588">第三步：在酒馆里粘贴 GitHub 地址</h3>
<p data-start="590" data-end="593">进入：</p>
<pre class="overflow-visible! px-0!" data-start="595" data-end="631"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>扩展</span><br><span>→ 安装扩展</span><br><span>→ 粘贴GitHub仓库地址</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="633" data-end="636">例如：</p>
<pre class="overflow-visible! px-0!" data-start="638" data-end="695"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>https://github.com/你的用户名/NGNL-Stockfish-Chess</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="697" data-end="803">然后酒馆会自动把整个扩展下载下来。SillyTavern官方支持通过“Install Extension”粘贴扩展仓库地址安装第三方扩展。<span class="" data-state="closed"><span class="ms-1 inline-flex max-w-full items-center select-none relative top-[-0.094rem] translate-y-0.5 animate-[show_150ms_ease-in]" data-testid="webpage-citation-pill" style="width: 124px;"><a href="https://docs.sillytavern.app/extensions/?utm_source=chatgpt.com" target="_blank" rel="noopener" alt="https://docs.sillytavern.app/extensions/?utm_source=chatgpt.com" class="flex overflow-hidden rounded-xl text-[9px] font-medium h-4.5 pe-2 ps-1 transition-colors duration-150 ease-in-out text-token-text-secondary! bg-[#F4F4F4]! dark:bg-[#303030]! select-none" style="max-width: 124px;"><span class="relative start-0 bottom-0 flex h-full w-full items-center"><span class="flex h-4 w-full items-center justify-between" style="opacity: 1; transform: none;"><span class="flex min-w-0 flex-1 items-center gap-1"><span class="inline-flex shrink-0 items-center justify-center overflow-hidden rounded-full"><img alt="" width="128" height="128" class="h-3 w-3 rounded-full" src="./stockfish-18-lite-single.wasm_files/favicons"></span><span class="max-w-[15ch] grow truncate overflow-hidden text-center">SillyTavern Documentation</span></span><span class="-me-1 flex h-full items-center rounded-full px-1 text-[#8F8F8F]">+1</span></span></span></a></span></span></p>
<h2 data-section-id="1wh8lk" data-start="805" data-end="814">最简单的答案</h2>
<p data-start="816" data-end="837">你问“这是GitHub还是脚本”，答案是：</p>
<pre class="overflow-visible! px-0!" data-start="839" data-end="889"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>类型：酒馆前端扩展</span><br><span>存放位置：GitHub仓库</span><br><span>安装方式：酒馆的“安装扩展”</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="891" data-end="897">不要导入到：</p>
<pre class="overflow-visible! px-0!" data-start="899" data-end="930"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>正则</span><br><span>快速回复</span><br><span>脚本库</span><br><span>世界书</span><br><span>角色卡</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<h2 data-section-id="1xf9esd" data-start="932" data-end="951">Stockfish为什么也能运行</h2>
<p data-start="953" data-end="982">虽然文件放在GitHub，但安装以后，酒馆会把它下载下来。</p>
<p data-start="984" data-end="990">之后下棋时：</p>
<pre class="overflow-visible! px-0!" data-start="992" data-end="1039"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>你控制空白走一步</span><br><span>↓</span><br><span>浏览器里的Stockfish计算</span><br><span>↓</span><br><span>特图走一步</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="1041" data-end="1167">计算是在浏览器中完成的，不会让GitHub替你计算，也不会消耗酒馆聊天模型额度。酒馆UI扩展本身可以运行浏览器JavaScript并操作界面，因此适合放棋盘和Stockfish。<span class="" data-state="closed"><span class="ms-1 inline-flex max-w-full items-center select-none relative top-[-0.094rem] translate-y-0.5 animate-[show_150ms_ease-in]" data-testid="webpage-citation-pill" style="width: 108px;"><a href="https://docs.sillytavern.app/for-contributors/writing-extensions/?utm_source=chatgpt.com" target="_blank" rel="noopener" alt="https://docs.sillytavern.app/for-contributors/writing-extensions/?utm_source=chatgpt.com" class="flex overflow-hidden rounded-xl text-[9px] font-medium h-4.5 pe-2 ps-1 transition-colors duration-150 ease-in-out text-token-text-secondary! bg-[#F4F4F4]! dark:bg-[#303030]! select-none" style="max-width: 108px;"><span class="relative start-0 bottom-0 flex h-full w-full items-center"><span class="flex h-4 w-full items-center justify-between overflow-hidden" style="opacity: 1; transform: none;"><span class="flex min-w-0 flex-1 items-center gap-1"><span class="inline-flex shrink-0 items-center justify-center overflow-hidden rounded-full"><img alt="" width="128" height="128" class="h-3 w-3 rounded-full" src="./stockfish-18-lite-single.wasm_files/favicons"></span><span class="max-w-[15ch] grow truncate overflow-hidden text-center">SillyTavern Documentation</span></span></span></span></a></span></span></p>
<p data-start="1169" data-end="1195">所以，我接下来应该给你的不是正则JSON，而是一个：</p>
<blockquote data-start="1197" data-end="1225">
<p data-start="1199" data-end="1225"><strong data-start="1199" data-end="1225">可以直接上传到GitHub的完整扩展代码包。</strong></p>
</blockquote>
<p data-start="1227" data-end="1249" data-is-last-node="" data-is-only-node="">上传GitHub后，把仓库地址填进酒馆即可。</p></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#51753c" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover round