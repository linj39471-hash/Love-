y_exposures\":[],\"id_type\":\"userID\",\"value\":false},\"4230914712\":{\"name\":\"4230914712\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":false}},\"dynamic_configs\":{\"944963740\":{\"name\":\"944963740\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"2133596510\":{\"name\":\"2133596510\",\"rule_id\":\"USeZB9iWAKvIVlivpomby\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"3359927663\":{\"name\":\"3359927663\",\"rule_id\":\"4PJfVH44agUI1KA3nvdZUW:0.00:2-6zr8aU9VHNUkRPlG8CwXPB\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"enabled\":false,\"max_pending_update_header_size_bytes\":0},\"is_device_based\":true,\"passed\":false},\"216497991\":{\"name\":\"216497991\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"outdated_room_bootstrap_messages_count\":10,\"max_file_size_mb\":5,\"idle_room_navigation_timeout_s\":900,\"sidebar_pagination_page_size\":6,\"sidebar_default_recent_room_row_count\":3,\"max_pinned_room_count\":2},\"is_device_based\":false,\"passed\":false},\"1967546325\":{\"name\":\"1967546325\",\"rule_id\":\"2bcszlc7CFHdfdCdq7jXNb:0.00:6\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{\"gdrivePicker\":false,\"gdrivePercentage\":0,\"oversmokeLink\":false,\"o365PersonalLink\":false,\"testCtor1Link\":false,\"gdriveLink\":false,\"o365Link\":false,\"oversmokePercentage\":0,\"showWorkspaceSettings\":false,\"o365Picker\":false,\"testCtor1Percentage\":0,\"o365Percentage\":0,\"loadTestPercentage\":0,\"o365BusinessLink\":false},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\",\"enable_web_search\":false},\"is_device_based\":false,\"passed\":false},\"3923090434\":{\"name\":\"3923090434\",\"rule_id\":\"3oWlxtnoHKmdKG6BLo9K8B:100.00:5-3oWlxrImfscJrgyGage6Pz\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"2026-06-22\":[\"Scan editors: You can now add scan editors to your configured repositories. Scan editors can update scans, including editing threat models, configuring notification rules, and managing scan sharing.\"],\"2026-05-04\":[\"Slack notifications: Get notified about new findings with the Codex Slack app. Go to the Scans page and select a scan you own to set up and customize alerts by severity, path, and keywords.\"],\"changelog_latest_date\":\"2026-06-22\"},\"is_device_based\":false,\"passed\":true},\"1249441125\":{\"name\":\"1249441125\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"727284014\":{\"name\":\"727284014\",\"rule_id\":\"510cco67RiDQNM8lncIPiy:100.00:12-510ccmr5p0umumApM4NbZw\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_additional_gmail_actions\":true,\"enable_gcal_write\":true,\"migrate_gmail\":false,\"migrate_gcontacts\":false,\"enable_gcal_in_api_tool\":true,\"enable_gmail_in_api_tool\":true,\"migrate_gcal\":false,\"migrate_p13n\":false,\"enable_gcontacts_in_api_tool\":true,\"enable_p13n_in_api_tool\":true},\"is_device_based\":false,\"passed\":true},\"3496620848\":{\"name\":\"3496620848\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"pdp_initial_visible_offers\":3,\"pdp_v2_prewarm_enabled\":false},\"is_device_based\":false,\"passed\":false},\"783652697\":{\"name\":\"783652697\",\"rule_id\":\"3Fk7LTbG3NkesGBOqbIJwe:100.00:4-3Fk7LRwDBvaK9h3SP3N6dc\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"chatgpt.go\":{\"myr\":2400,\"kzt\":339000,\"usd-sc\":800,\"usd-mu\":600,\"nok\":9900,\"krw\":1300000,\"jpy\":140000,\"gbp\":700,\"usd-mv\":600,\"usd-re\":800,\"sgd\":1100,\"nzd\":1400,\"usd-yt\":800,\"usd-bn\":600,\"sek\":8500,\"dkk\":6400,\"aed\":3000,\"twd\":27000,\"ils\":2500,\"eur-es\":800,\"czk\":20000}},\"is_device_based\":true,\"passed\":true},\"2281515186\":{\"name\":\"2281515186\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"2860872286\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"2428869993\",\"gateValue\":\"false\