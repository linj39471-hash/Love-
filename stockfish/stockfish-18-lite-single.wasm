-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="bc8fc810-358c-4e0c-a3e1-4518a0920f6c" data-turn-id-container="bc8fc810-358c-4e0c-a3e1-4518a0920f6c" data-testid="conversation-turn-22" data-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="b00b8841-de4f-4dc7-87b3-7db825eab7a3" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="b00b8841-de4f-4dc7-87b3-7db825eab7a3" data-turn-id-container="b00b8841-de4f-4dc7-87b3-7db825eab7a3" data-testid="conversation-turn-23" data-turn="user"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="0ddc4642-be26-410a-aed9-b3573cdab3fe" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="0ddc4642-be26-410a-aed9-b3573cdab3fe" data-turn-id-container="0ddc4642-be26-410a-aed9-b3573cdab3fe" data-testid="conversation-turn-24" data-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="b46a0f12-0a30-495e-8a11-4a1929ad5fc3" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="b46a0f12-0a30-495e-8a11-4a1929ad5fc3" data-turn-id-container="b46a0f12-0a30-495e-8a11-4a1929ad5fc3" data-testid="conversation-turn-25" data-turn="user"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="c9c7ce06-cbdf-4376-8710-406611787a08" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="c9c7ce06-cbdf-4376-8710-406611787a08" data-turn-id-container="c9c7ce06-cbdf-4376-8710-406611787a08" data-testid="conversation-turn-26" data-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="daed4c4c-1d47-4c30-bdb1-b1c0d9470fb9" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="daed4c4c-1d47-4c30-bdb1-b1c0d9470fb9" data-turn-id-container="daed4c4c-1d47-4c30-bdb1-b1c0d9470fb9" data-testid="conversation-turn-27" data-turn="user"></section></div><div class="" data-turn-id-container="7a28f3a7-b87e-4989-b649-8fcef70fd844" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="7a28f3a7-b87e-4989-b649-8fcef70fd844" data-turn-id-container="7a28f3a7-b87e-4989-b649-8fcef70fd844" data-testid="conversation-turn-28" data-turn="assistant"><h4 class="sr-only select-none">ChatGPT said:</h4><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div data-conversation-screenshot-content="" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div class="flex items-center justify-between"><div class="flex min-w-0 items-center"><button type="button" class="text-token-text-tertiary hover:text-token-text-primary dark:hover:text-token-text-primary flex items-center gap-0.5 text-start dark:text-(--interactive-label-tertiary-default)">Thought for a few seconds<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="icon-xs"><use href="/cdn/assets/sprites-core-c74d0474.svg#b140e7" fill="currentColor"></use></svg></button></div></div><div data-message-author-role="assistant" data-message-id="38c6ecc0-97aa-411d-b43e-805874deffea" dir="auto" data-message-model-slug="gpt-5-5-thinking" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full light markdown-new-styling"><p data-start="0" data-end="6">最简单理解：</p>
<ul data-start="8" data-end="89">
<li data-section-id="1bmuhho" data-start="8" data-end="26">
<p data-start="10" data-end="26"><strong data-start="10" data-end="16">正则</strong>＝把棋盘“显示出来”</p>
</li>
<li data-section-id="1fhxpxm" data-start="27" data-end="58">
<p data-start="29" data-end="58"><strong data-start="29" data-end="42">Stockfish</strong>＝真正负责思考怎么下棋的“大脑”</p>
</li>
<li data-section-id="1u3nqjw" data-start="59" data-end="89">
<p data-start="61" data-end="89"><strong data-start="61" data-end="69">酒馆扩展</strong>＝让这个“大脑”能在酒馆里正常运行的工具</p>
</li>
</ul>
<p data-start="91" data-end="103">你现在的正则版本相当于：</p>
<blockquote data-start="105" data-end="121">
<p data-start="107" data-end="121">棋盘 + 一个我写的小型AI</p>
</blockquote>
<p data-start="123" data-end="149">它能自动下棋，但没有真正的 Stockfish 强。</p>
<p data-start="151" data-end="174">如果要用真正的 Stockfish，就像这样：</p>
<pre class="overflow-visible! px-0!" data-start="176" data-end="272"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>你操作空白下棋</span><br><span>        ↓</span><br><span>棋盘把局面交给 Stockfish</span><br><span>        ↓</span><br><span>Stockfish 在电脑本地思考</span><br><span>        ↓</span><br><span>特图自动走出最佳棋步</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="274" data-end="322">Stockfish 不会使用酒馆的AI，也不会消耗你的API额度。它直接在你的电脑浏览器里运行。</p>
<h2 data-section-id="66snb2" data-start="324" data-end="345">为什么正则不适合 Stockfish</h2>
<p data-start="347" data-end="374">因为真正的 Stockfish 通常需要两个额外文件：</p>
<pre class="overflow-visible! px-0!" data-start="376" data-end="415"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>stockfish.js</span><br><span>stockfish.wasm</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="417" data-end="451">而酒馆正则主要只能处理文字和HTML，很难把这两个引擎文件一起导入。</p>
<p data-start="453" data-end="460">可以这样理解：</p>
<blockquote data-start="462" data-end="509">
<p data-start="464" data-end="509">正则像一张海报，可以画出棋盘；<br data-start="479" data-end="482">
Stockfish像一台电脑，不能直接塞进海报里。</p>
</blockquote>
<h2 data-section-id="v40dtp" data-start="511" data-end="521">最适合你的方式</h2>
<p data-start="523" data-end="527">要实现：</p>
<ul data-start="529" data-end="581">
<li data-section-id="1n9m3we" data-start="529" data-end="536">
<p data-start="531" data-end="536">你控制空白</p>
</li>
<li data-section-id="164zt2o" data-start="537" data-end="558">
<p data-start="539" data-end="558">特图使用真正的高强度Stockfish</p>
</li>
<li data-section-id="1qaxee4" data-start="559" data-end="572">
<p data-start="561" data-end="572">在酒馆里面直接显示棋盘</p>
</li>
<li data-section-id="qoiqoi" data-start="573" data-end="581">
<p data-start="575" data-end="581">特图自动应棋</p>
</li>
</ul>
<p data-start="583" data-end="607">最稳定的方法就是安装一个<strong data-start="595" data-end="606">酒馆扩展文件夹</strong>。</p>
<p data-start="609" data-end="624">使用时不需要操作代码，只需要：</p>
<pre class="overflow-visible! px-0!" data-start="626" data-end="688"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼd ͼr"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>1. 下载扩展压缩包</span><br><span>2. 解压</span><br><span>3. 把文件夹放进酒馆扩展目录</span><br><span>4. 重启酒馆</span><br><span>5. 点击棋盘按钮</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<h2 data-section-id="xz5h6i" data-start="690" data-end="700">两个版本的区别</h2>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="702" data-end="805" class="w-fit min-w-(--thread-content-width)"><thead data-start="702" data-end="722"><tr data-start="702" data-end="722"><th data-start="702" data-end="707" data-col-size="sm" class="last:pe-10">版本</th><th data-start="707" data-end="714" data-col-size="sm" class="last:pe-10">安装方式</th><th data-start="714" data-end="722" data-col-size="sm" class="last:pe-10">特图棋力</th></tr></thead><tbody data-start="737" data-end="805"><tr data-start="737" data-end="765"><td data-start="737" data-end="746" data-col-size="sm">现在的正则版</td><td data-start="746" data-end="755" data-col-size="sm">导入JSON</td><td data-start="755" data-end="765" data-col-size="sm">普通本地AI</td></tr><tr data-start="766" data-end="805"><td data-start="766" data-end="781" data-col-size="sm">Stockfish扩展版</td><td data-start="781" data-end="791" data-col-size="sm">文件夹放入酒馆</td><td data-start="791" data-end="805" data-col-size="sm">极强，远强于普通玩家</td></tr></tbody></table><div class="relative h-0 self-end select-none"><div class="absolute end-0 flex items-end" style="height: 32.7188px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary relative z-10 my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
<p data-start="807" data-end="813">一句话总结：</p>
<blockquote data-start="815" data-end="885" data-is-last-node="" data-is-only-node="">
<p data-start="817" data-end="885" data-is-last-node=""><strong data-start="817" data-end="885" data-is-last-node="">酒馆可以运行Stockfish，但最好不要用正则运行，而是用酒馆扩展运行。正则负责显示，扩展负责让真正的Stockfish工作。</strong></p>
</blockquote></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#ce3544" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-c74d0474.svg#51753c" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Bad response" aria-pressed="false" data-testid="bad-response-turn-action-